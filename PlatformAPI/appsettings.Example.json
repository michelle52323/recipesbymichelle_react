{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "IsLive": false,
  "UseMockLogin": false,

  "DatabaseConnection": "LiveConnection",

  "ConnectionStrings": {
    "LiveConnection": "Server=YOUR_SERVER_HERE;Database=YOUR_DATABASE_NAME;User ID=YOUR_USERNAME;Password=YOUR_PASSWORD;Encrypt=True;TrustServerCertificate=True;"
  },

  "EmailSettings": {
    "AdminEmail": "YOUR_ADMIN_EMAIL_HERE",
    "AdminPassword": "YOUR_EMAIL_PASSWORD_OR_APP_PASSWORD_HERE",
    "Smtp": "YOUR_SMTP_SERVER_HERE",
    "SmtpPort": 587,
    "UseSSL": false,
    "UseStartTls": true
  },

  "OrganizationSettings": {
    "OrganizatioName": "Quiz Builder",
    "OrganizationUrl": "https://www.yourdomain.com/"
  }
}
